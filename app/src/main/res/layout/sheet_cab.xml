<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#161616"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔊 Cabinet Simulation (IR)"
        android:textColor="#FFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="حمّل ملف .wav (Impulse Response) لمحاكاة كابينة المضخم"
        android:textColor="#888"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"/>

    <!-- Current cab -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvCabCurrent"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="لا يوجد Cabinet"
            android:textColor="#AAA"
            android:textSize="13sp"/>

        <Switch
            android:id="@+id/switchCab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#FF9800"
            android:trackTint="#333"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnLoadCab"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:text="📂 تحميل ملف WAV"
        android:backgroundTint="#FF9800"
        android:textColor="#000"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnClearCab"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="🗑 إزالة Cabinet"
        android:backgroundTint="#333"
        android:textColor="#EEE"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="💡 يمكن تحميل ملفات IR مجانية من:\nwww.recabinet.com · www.guitarix.org"
        android:textColor="#555"
        android:textSize="11sp"/>
</LinearLayout>
